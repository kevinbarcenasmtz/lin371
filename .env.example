# FMP Earnings Transcript API key.
# Used by scripts/pull_fmp_transcripts.py and notebooks/04_FMP_Data_Collection.ipynb.
# Sign up at https://site.financialmodelingprep.com to obtain.
FMP_API_KEY=your_fmp_api_key_here

# Kalshi Trade API authentication.
# ONLY needed for notebooks/07_Trading_Recommender.ipynb (live recommendation
# pull from active markets). The numbers reported in §5.5 of the final paper
# come from notebook 05's held-out test split, NOT from notebook 07, so the
# core pipeline reproduces without these.
#
# KALSHI_KEY_ID:    your Kalshi access-key UUID (from the Kalshi web dashboard).
# KALSHI_KEY_FILE:  path to the corresponding RSA private key in PEM format
#                   (downloaded once when the key is created; do not commit).
# Auth is RSA-PSS over SHA-256; see notebook 07 cell `auth` for the signing flow.
KALSHI_KEY_ID=your_kalshi_access_key_uuid_here
KALSHI_KEY_FILE=kalshi_key.key
